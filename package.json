{
  "name": "riddim-website",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "rm -rf _site && eleventy",
    "dev": "eleventy --serve --watch",
    "lint:css": "stylelint default.css",
    "validate": "npm run lint:css && npm run build && VALIDATE_SITE_ROOT=_site python3 scripts/validate.py",
    "lighthouse:mobile": "lhci autorun --config=.lighthouserc.mobile.cjs",
    "lighthouse:desktop": "lhci autorun --config=.lighthouserc.desktop.cjs",
    "a11y:baseline": "node scripts/axe-baseline.mjs",
    "audit:ci": "bash scripts/run-quality-audits.sh"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@lhci/cli": "^0.15.1",
    "axe-core": "^4.11.0",
    "playwright": "^1.54.0",
    "stylelint": "^17.11.0"
  }
}
