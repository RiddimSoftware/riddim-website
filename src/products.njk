---
pagination:
  data: productPages
  size: 1
  alias: product
permalink: "{{ product.slug }}/index.html"
---
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ product.title }}</title>
  <meta name="description" content="{{ product.description }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Riddim Software">
  <meta property="og:title" content="{{ product.title }}">
  <meta property="og:description" content="{{ product.description }}">
  <meta property="og:url" content="{{ product.canonical }}">
  <meta property="og:image" content="https://riddimsoftware.com/{{ product.icon }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ product.title }}">
  <meta name="twitter:description" content="{{ product.description }}">
  <meta name="twitter:image" content="https://riddimsoftware.com/{{ product.icon }}">
  <link rel="stylesheet" href="../default.css">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="canonical" href="{{ product.canonical }}">
</head>

<body>
  <header>
    <a href="/"><img style="max-height: 128px; height: 10svh;" src="../wordmark.png" alt="Riddim Software" /></a>
  </header>
  <a class="back-link" href="/">&larr; All products</a>
  <section class="light_background">
    <div class="product-hero">
      <img class="product-icon" src="../{{ product.icon }}" alt="{{ product.iconAlt }}" />
      <h1>{{ product.name }}</h1>
      <p class="product-tagline">{{ product.tagline }}</p>
      <div class="cta-group">
        {%- for cta in product.ctas %}
        <a class="{{ cta.className }}" href="{{ cta.href }}"{% if cta.external %} target="_blank" rel="noopener"{% endif %}>{% if cta.appStoreIcon %}
          <img src="../app-store.svg" alt="App Store" style="height:1em; vertical-align:middle; margin-right:6px;">{% endif %}{{ cta.label }}</a>
        {%- endfor %}
      </div>
    </div>
  </section>
  <footer class="light_background">
    <p>&copy; Riddim Software</p>
  </footer>
</body>

</html>
