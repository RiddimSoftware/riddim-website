<div class="theme-toggle" data-theme-toggle>
  <span class="theme-toggle-label" id="theme-toggle-label">Theme</span>
  <div class="theme-toggle-control">
    <div class="theme-toggle-group" role="group" aria-label="Theme" aria-labelledby="theme-toggle-label">
      <button type="button" class="theme-toggle-option" data-theme-option="system" aria-label="Use system theme" aria-pressed="false" aria-describedby="theme-status">
        <span class="theme-toggle-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><rect x="4" y="5" width="16" height="11" rx="2"></rect><path d="M9 19h6"></path><path d="M12 16v3"></path></svg>
        </span>
        <span class="sr-only">System</span>
      </button>
      <button type="button" class="theme-toggle-option" data-theme-option="light" aria-label="Use light theme" aria-pressed="false" aria-describedby="theme-status">
        <span class="theme-toggle-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2.5"></path><path d="M12 19.5V22"></path><path d="M4.93 4.93l1.77 1.77"></path><path d="M17.3 17.3l1.77 1.77"></path><path d="M2 12h2.5"></path><path d="M19.5 12H22"></path><path d="M4.93 19.07l1.77-1.77"></path><path d="M17.3 6.7l1.77-1.77"></path></svg>
        </span>
        <span class="sr-only">Light</span>
      </button>
      <button type="button" class="theme-toggle-option" data-theme-option="dark" aria-label="Use dark theme" aria-pressed="false" aria-describedby="theme-status">
        <span class="theme-toggle-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><path d="M14.5 4.5a7.5 7.5 0 1 0 5 13.1 8 8 0 1 1-5-13.1Z"></path></svg>
        </span>
        <span class="sr-only">Dark</span>
      </button>
    </div>
    <span id="theme-status" class="theme-toggle-status" data-theme-status aria-live="polite" aria-atomic="true">Following system</span>
  </div>
</div>
