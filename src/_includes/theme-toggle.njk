<div class="theme-toggle" data-theme-toggle>
  <label class="theme-toggle-label" for="theme-select">Theme</label>
  <div class="theme-toggle-control">
    <select id="theme-select" class="theme-toggle-select" data-theme-select aria-describedby="theme-status">
      <option value="system">System</option>
      <option value="light">Light</option>
      <option value="dark">Dark</option>
    </select>
    <span id="theme-status" class="theme-toggle-status" data-theme-status aria-live="polite">Following system</span>
  </div>
</div>
