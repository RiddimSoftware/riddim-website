<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ product.seo.title }}</title>
  <meta name="description" content="{{ product.seo.description }}">
  {% include "font-links.njk" %}
  {% include "theme-head.njk" %}
  <link rel="stylesheet" href="/default.css">
  <script src="/assets/theme.js" defer></script>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#1c2d42">
  <link rel="canonical" href="{{ product.seo.canonical }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Riddim Software">
  <meta property="og:title" content="{{ product.seo.title }}">
  <meta property="og:description" content="{{ product.seo.description }}">
  <meta property="og:url" content="{{ product.seo.canonical }}">
  <meta property="og:image" content="{{ product.seo.ogImage }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ product.seo.title }}">
  <meta name="twitter:description" content="{{ product.seo.description }}">
  <meta name="twitter:image" content="{{ product.seo.ogImage }}">
</head>

<body>
  <header class="product-header">
    <a class="wordmark-link" href="/" aria-label="Riddim Software home">
      {% include "wordmark.njk" %}
    </a>
    {% include "theme-toggle.njk" %}
  </header>
  <main class="product-page">
    <a class="back-link" href="/">&larr; All products</a>
    <section class="light_background">
      <div class="product-hero">
        <img
          class="product-icon"
          src="{{ product.icon | assetUrl }}"
          alt="{{ product.iconAlt }}"
          width="{{ product.iconWidth }}"
          height="{{ product.iconHeight }}"
          decoding="async"
          fetchpriority="high" />
        <h1>{{ product.name }}</h1>
        <p class="product-tagline">{{ product.tagline }}</p>
        <div class="cta-group">
          {%- if product.primaryCta %}
          <a class="{% if product.primaryCta.appStoreBadge %}app-store-badge-link{% else %}btn btn-primary{% endif %}" href="{{ product.primaryCta.href }}"{% if product.primaryCta.external %} target="_blank" rel="noopener"{% endif %}{% if product.primaryCta.appStoreBadge %} aria-label="{{ product.primaryCta.label }}"{% endif %}>{% if product.primaryCta.appStoreBadge %}
            <img class="app-store-badge" src="/app-store.svg" alt="{{ product.primaryCta.label }}">{% elif product.primaryCta.appStoreIcon %}
            <img class="button-icon" src="/app-store.svg" alt="" aria-hidden="true">{% endif %}{% if not product.primaryCta.appStoreBadge %}{{ product.primaryCta.label }}{% endif %}</a>
          {%- endif %}
          {%- if product.secondaryLinksInHero and product.secondaryLinks and product.secondaryLinks.length %}
          {%- for link in product.secondaryLinks %}
          <a class="btn btn-secondary" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>{{ link.label }}</a>
          {%- endfor %}
          {%- endif %}
          {%- if product.heroSecondaryCta %}
          <a class="btn btn-secondary" href="{{ product.heroSecondaryCta.href }}"{% if product.heroSecondaryCta.external %} target="_blank" rel="noopener"{% endif %}>{{ product.heroSecondaryCta.label }}</a>
          {%- endif %}
        </div>
      </div>
    </section>
    <section class="product-story light_background">
      <div class="product-section-inner">
        {%- if product.storyEyebrow %}
        <p class="eyebrow">{{ product.storyEyebrow }}</p>
        {%- endif %}
        <h2>{{ product.storyTitle or "Story" }}</h2>
        <p>{{ product.story }}</p>
      </div>
    </section>
    <section class="product-screenshots light_background" aria-label="{{ product.name }} screenshots">
      {%- if product.screenshotsTitle %}
      <div class="product-section-inner product-screenshots-copy">
        {%- if product.screenshotsEyebrow %}
        <p class="eyebrow">{{ product.screenshotsEyebrow }}</p>
        {%- endif %}
        <h2>{{ product.screenshotsTitle }}</h2>
        {%- if product.screenshotsIntro %}
        <p>{{ product.screenshotsIntro }}</p>
        {%- endif %}
      </div>
      {%- endif %}
      <div class="screenshot-strip{% if product.screenshotLayout %} {{ product.screenshotLayout }}{% endif %}">
        {%- for screenshot in product.screenshots %}
        <figure>
          <img src="{{ screenshot.src | assetUrl }}" alt="{{ screenshot.alt }}"{% if screenshot.width %} width="{{ screenshot.width }}"{% endif %}{% if screenshot.height %} height="{{ screenshot.height }}"{% endif %} loading="lazy" decoding="async">
          {%- if screenshot.caption %}
          <figcaption>{{ screenshot.caption }}</figcaption>
          {%- endif %}
        </figure>
        {%- endfor %}
      </div>
    </section>
    <section class="product-features light_background">
      <div class="product-section-inner">
        <h2>{{ product.featuresTitle or "Features" }}</h2>
        {%- if product.featuresIntro %}
        <p>{{ product.featuresIntro }}</p>
        {%- endif %}
        <ul class="feature-list">
          {%- for feature in product.features %}
          <li>{% if feature.title %}<strong>{{ feature.title }}</strong><span>{{ feature.description }}</span>{% else %}{{ feature }}{% endif %}</li>
          {%- endfor %}
        </ul>
      </div>
    </section>
    {%- if product.secondaryLinks and product.secondaryLinks.length and not product.secondaryLinksInHero %}
    <section class="product-secondary-links light_background">
      <div class="cta-group">
        {%- for link in product.secondaryLinks %}
        <a class="btn btn-secondary" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>{{ link.label }}</a>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}
  </main>
  {% include "site-footer.njk" %}
</body>

</html>
